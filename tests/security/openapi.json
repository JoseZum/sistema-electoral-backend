  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "Id": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string", "format": "uuid" },
        "example": "00000000-0000-0000-0000-000000000001"
      },
      "OptionId": {
        "name": "optionId",
        "in": "path",
        "required": true,
        "schema": { "type": "string", "format": "uuid" },
        "example": "00000000-0000-0000-0000-000000000002"
      },
      "ElectionId": {
        "name": "electionId",
        "in": "path",
        "required": true,
        "schema": { "type": "string", "format": "uuid" },
        "example": "00000000-0000-0000-0000-000000000001"
      },
      "Page": {
        "name": "page",
        "in": "query",
        "schema": { "type": "integer", "minimum": 1, "default": 1 },
        "example": 1
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 30 },
        "example": 30
      }
    },
    "responses": {
      "JsonObject": {
        "description": "JSON object response",
        "content": {
          "application/json": {
            "schema": { "type": "object", "additionalProperties": true }
          }
        }
      },
      "JsonArray": {
        "description": "JSON array response",
        "content": {
          "application/json": {
            "schema": {
              "type": "array",
              "items": { "type": "object", "additionalProperties": true }
            }
          }
        }
      },
      "Error": {
        "description": "Error response",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "error": { "type": "string", "example": "No autenticado" },
          "message": { "type": "string", "example": "Solicitud invalida" },
          "code": { "type": "string", "example": "VALIDATION_ERROR" }
        }
      },
      "StudentInput": {
        "type": "object",
        "required": ["carnet", "email", "full_name"],
        "properties": {
          "carnet": { "type": "string", "example": "2026000010" },
          "email": { "type": "string", "format": "email", "example": "student@estudiantec.cr" },
          "full_name": { "type": "string", "example": "Maria Prueba" },
          "career": { "type": "string", "example": "Computacion" },
          "sede": { "type": "string", "example": "Cartago" },
          "is_active": { "type": "boolean", "example": true }
        }
      },
      "StudentPatch": {
        "allOf": [{ "$ref": "#/components/schemas/StudentInput" }]
      },
      "AdminInput": {
        "type": "object",
        "properties": {
          "student_id": {
            "type": "string",
            "format": "uuid",
            "example": "00000000-0000-0000-0000-000000000001"
          },
          "role": { "type": "string", "example": "admin" },
          "is_active": { "type": "boolean", "example": true }
        }
      },
      "ElectionInput": {
        "type": "object",
        "required": ["title", "start_date", "end_date"],
        "properties": {
          "title": { "type": "string", "example": "Eleccion de prueba ZAP" },
          "description": { "type": "string", "example": "Escenario automatizado de seguridad" },
          "election_type": { "type": "string", "example": "INTERNA" },
          "status": { "type": "string", "example": "draft" },
          "start_date": { "type": "string", "format": "date-time", "example": "2026-06-01T08:00:00.000Z" },
          "end_date": { "type": "string", "format": "date-time", "example": "2026-06-01T18:00:00.000Z" },
          "is_anonymous": { "type": "boolean", "example": true },
          "allow_blank_vote": { "type": "boolean", "example": true },
          "requires_key_ceremony": { "type": "boolean", "example": false },
          "key_threshold": { "type": "integer", "minimum": 1, "example": 2 }
        }
      },
      "ElectionPatch": {
        "allOf": [{ "$ref": "#/components/schemas/ElectionInput" }]
      },
      "ElectionStatus": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": { "type": "string", "enum": ["draft", "scheduled", "open", "closed", "cancelled"], "example": "open" }
        }
      },
      "ElectionOptionInput": {
        "type": "object",
        "required": ["label"],
        "properties": {
          "label": { "type": "string", "example": "Opcion A" },
          "description": { "type": "string", "example": "Descripcion de opcion" },
          "display_order": { "type": "integer", "minimum": 1, "example": 1 }
        }
      },
      "PopulateVotersRequest": {
        "type": "object",
        "properties": {
          "mode": { "type": "string", "enum": ["all", "tag", "manual"], "example": "manual" },
          "tagId": {
            "type": "string",
            "format": "uuid",
            "example": "00000000-0000-0000-0000-000000000003"
          },
          "studentIds": {
            "type": "array",
            "items": { "type": "string", "format": "uuid" },
            "example": ["00000000-0000-0000-0000-000000000001"]
          }
        }
      },
      "TagInput": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "example": "Padron ZAP" },
          "description": { "type": "string", "example": "Grupo de prueba" },
          "color": { "type": "string", "example": "#2563eb" },
          "studentIds": {
            "type": "array",
            "items": { "type": "string", "format": "uuid" },
            "example": ["00000000-0000-0000-0000-000000000001"]
          }
        }
      },
      "CastVoteRequest": {
        "type": "object",
        "required": ["electionId", "optionId"],
        "properties": {
          "electionId": {
            "type": "string",
            "format": "uuid",
            "example": "00000000-0000-0000-0000-000000000001"
          },
          "optionId": {
            "type": "string",
            "format": "uuid",
            "example": "00000000-0000-0000-0000-000000000002"
          }
        }
      },
      "AuditPurgeRequest": {
        "type": "object",
        "properties": {
          "from": { "type": "string", "format": "date", "example": "2026-01-01" },
          "to": { "type": "string", "format": "date", "example": "2026-01-31" },
          "resource_types": {
            "type": "array",
            "items": { "type": "string" },
            "example": ["student"]
          },
          "action": { "type": "string", "example": "student.insert" }
        }
      },
      "ScrutinyMembersRequest": {
        "type": "object",
        "properties": {
          "members": {
            "type": "array",
            "items": { "type": "string", "format": "uuid" },
            "example": ["00000000-0000-0000-0000-000000000001"]
          },
          "threshold": { "type": "integer", "minimum": 1, "example": 2 }
        }
      },
      "SubmitKeyRequest": {
        "type": "object",
        "required": ["key"],
        "properties": {
          "memberId": {
            "type": "string",
            "format": "uuid",
            "example": "00000000-0000-0000-0000-000000000001"
          },
          "key": { "type": "string", "example": "1-a1b2c3d4" }
        }
      }
    }
  }
}

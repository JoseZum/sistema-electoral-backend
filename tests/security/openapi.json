        "parameters": [
          { "name": "format", "in": "query", "schema": { "type": "string", "enum": ["csv", "json"] }, "example": "json" },
          { "name": "resource_types", "in": "query", "schema": { "type": "string" }, "example": "student,election" },
          { "name": "from", "in": "query", "schema": { "type": "string", "format": "date" }, "example": "2026-01-01" },
          { "name": "to", "in": "query", "schema": { "type": "string", "format": "date" }, "example": "2026-12-31" }
        ],
        "responses": {
          "200": { "description": "Audit export file" },
          "401": { "$ref": "#/components/responses/Error" },
          "403": { "$ref": "#/components/responses/Error" }
        }
      }
    },

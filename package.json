{
  "name": "sistema-electoral-backend",
  "version": "1.0.0",
  "description": "TEE Voting System - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:concurrency": "vitest run tests/concurrency --fileParallelism=false",
    "test:security": "npm run test:security:vulnerabilities",
    "test:security:vulnerabilities": "node tests/security/vulnerabilityAudit.mjs",
    "test:security:zap": "node tests/security/zapApiScan.mjs",
    "test:ui": "vitest --ui",
    "test:dashboard:smoke": "ts-node src/scripts/dashboardSmokeTest.ts"
  },
  "overrides": {
    "path-to-regexp": "0.1.13"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "multer": "^2.1.1",
    "pg": "^8.13.1",
    "read-excel-file": "^9.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@vitest/ui": "^2.1.8",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "xlsx": "^0.18.5"
  }
}
